<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvDetaliiRezervare"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Detalii vehicul"
            android:textSize="18sp"
            android:paddingBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Alege tariful:" />

        <RadioGroup
            android:id="@+id/rgTarife"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton android:id="@+id/rb1min" android:text="0.50 lei / min"  android:layout_width="match_parent" android:layout_height="wrap_content"/>
            <RadioButton android:id="@+id/rb1h" android:text="10.00 lei / oră" android:layout_width="match_parent" android:layout_height="wrap_content"/>
            <RadioButton android:id="@+id/rb12h" android:text="49.00 lei / 12 ore" android:layout_width="match_parent" android:layout_height="wrap_content"/>
            <RadioButton android:id="@+id/rb24h" android:text="89.00 lei / 24 ore" android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </RadioGroup>

        <Button
            android:id="@+id/btnConfirmaRezervare"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Confirmă rezervarea"
            android:layout_marginTop="24dp" />
    </LinearLayout>
</ScrollView>
